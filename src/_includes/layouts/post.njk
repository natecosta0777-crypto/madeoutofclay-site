---
layout: layouts/base.njk
schemaArticle: true
---
<article class="section">
  <div class="wrap prose">
    <p class="post-meta"><a href="/blog/">&larr; All posts</a></p>
    <h1>{{ title }}</h1>
    <p class="post-meta"><time datetime="{{ page.date | isoDate }}">{{ page.date | readableDate }}</time> · By {{ site.authorPenName }}</p>
    {{ content | safe }}
    <hr>
    <p><a class="btn btn-primary" href="/books/">Browse the books</a></p>
  </div>
</article>
