---
layout: layouts/base.njk
permalink: /contact/
title: "Contact — Made Out of Clay Productions"
description: "Wholesale, library, and review-copy inquiries for Made Out of Clay Productions children's books."
breadcrumbs:
  - { name: "Home", url: "/" }
  - { name: "Contact", url: "/contact/" }
---
<section class="page-head">
  <div class="wrap">
    <h1>Get in touch</h1>
    <p>Wholesale, library, classroom, review copies, interviews, or just to say hello — we read every message.</p>
  </div>
</section>

<section class="section">
  <div class="wrap">
    {% if site.contactAction %}
    <form class="contact-form" action="{{ site.contactAction }}" method="post"
          data-track="contact_submit" novalidate>
      <div>
        <label for="c-name">Name</label>
        <input id="c-name" type="text" name="name" required autocomplete="name">
      </div>
      <div>
        <label for="c-email">Email</label>
        <input id="c-email" type="email" name="email" required autocomplete="email">
      </div>
      <div>
        <label for="c-type">Inquiry type</label>
        <select id="c-type" name="inquiry_type">
          <option value="general">General</option>
          <option value="wholesale">Wholesale / bulk order</option>
          <option value="library">Library</option>
          <option value="classroom">Classroom</option>
          <option value="review-copy">Review copy</option>
          <option value="interview">Interview / press</option>
        </select>
      </div>
      <div>
        <label for="c-message">Message</label>
        <textarea id="c-message" name="message" required></textarea>
      </div>
      {# Honeypot #}
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="visually-hidden" aria-hidden="true">
      <div>
        <button class="btn btn-primary btn-lg" type="submit">Send message</button>
      </div>
      <p class="form-status" role="status" aria-live="polite"></p>
    </form>
    {% else %}
    <div class="prose">
      <p>The fastest way to reach us is email — we read every message:</p>
      <p><a class="btn btn-primary btn-lg" href="mailto:{{ site.email }}">{{ site.email }}</a></p>
      <p class="form-fineprint">We read every message — expect a reply within two business days.</p>
    </div>
    {% endif %}
  </div>
</section>
