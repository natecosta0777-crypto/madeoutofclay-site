{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "_site",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.madeoutofclayprod.com" }],
      "destination": "https://madeoutofclayprod.com/:path*",
      "permanent": true
    }
  ]
}
